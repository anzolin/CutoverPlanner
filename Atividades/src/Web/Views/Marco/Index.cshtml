@model IEnumerable<CutoverManager.Application.DTOs.MarcoDTO>
@{
    ViewData["Title"] = "Marcos";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">
            <i class="fas fa-flag"></i> Marcos
        </h3>

        <a href="/Marco/Create">
            <i class="fas fa-plus"></i> Novo Marco
        </a>
    </div>

    <div class="card-body">

        <table class="table table-hover table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Nome</th>
                    <th style="width:150px;">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td><strong>@m.Nome</strong></td>

                        <td>
                            <a href="/Marco/Edit/@m.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-edit"></i>
                            </a>

                            <a href="/Marco/Delete/@m.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>