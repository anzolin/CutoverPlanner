@{
    Layout = null;
}

<!doctype html>
<html lang="pt-br" data-bs-theme="light">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Cutover Manager</title>

    <!-- Tabler Core CSS -->
    <link href="~/tabler/css/tabler.min.css" rel="stylesheet" />

    <!-- Tabler Icons -->
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />

    <!-- Tabler Additional Plugins (opcional) -->
    <link href="~/tabler/css/tabler-flags.min.css" rel="stylesheet" />
    <link href="~/tabler/css/tabler-payments.min.css" rel="stylesheet" />
    <link href="~/tabler/css/tabler-vendors.min.css" rel="stylesheet" />

    @RenderSection("Styles", required: false)
</head>

<body>

    <div class="page">

        <!-- Header -->
        @await Html.PartialAsync("_Header")

        <!-- Page Wrapper -->
        <div class="page-wrapper">

            @RenderBody()

            <!-- Footer -->
            @await Html.PartialAsync("_Footer")

        </div>
    </div>


    <!-- Tabler Core JS -->
    <script src="~/tabler/js/tabler.min.js">"</script>

    @RenderSection("Scripts", required: false)
</body>

</html>