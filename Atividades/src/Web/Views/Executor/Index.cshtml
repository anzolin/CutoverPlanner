@model IEnumerable<CutoverManager.Application.DTOs.ExecutorDTO>
@{
    ViewData["Title"] = "Executores";
}

<!-- BEGIN PAGE HEADER -->
<div class="page-header d-print-none" aria-label="Page header">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <!-- Page pre-title -->
                @* <div class="page-pretitle"></div> *@
                <h2 class="page-title">@ViewData["Title"]</h2>
            </div>
            <!-- Page title actions -->
            <div class="col-auto ms-auto d-print-none">
                <div class="btn-list">
                    <span class="d-none d-sm-inline">
                        <a href="/Executor" class="btn btn-1">Atualizar</a>
                    </span>
                    <span class="d-none d-sm-inline">
                        <a href="/Executor/Create" class="btn btn-primary btn-5">Novo</a>
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- END PAGE HEADER -->

<!-- BEGIN PAGE BODY -->
<div class="page-body">
    <div class="container-xl">
        <div class="row row-deck row-cards">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Listagem de @ViewData["Title"]</h3>
                    </div>
                    @* <div class="card-body border-bottom py-3">
                        <div class="d-flex">
                            <div class="text-secondary">
                                Show
                                <div class="mx-2 d-inline-block">
                                    <input type="text" class="form-control form-control-sm" value="8" size="3" aria-label="Invoices count">
                                </div>
                                entries
                            </div>
                            <div class="ms-auto text-secondary">
                                Search:
                                <div class="ms-2 d-inline-block">
                                    <input type="text" class="form-control form-control-sm" aria-label="Search invoice">
                                </div>
                            </div>
                        </div>
                    </div> *@
                    <div class="table-responsive">
                        <table class="table table-vcenter card-table table-striped">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Área</th>
                                    <th>Nome</th>
                                    <th>Email</th>
                                    <th class="w-1"></th>
                                    <th class="w-1"></th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var e in Model)
                                {
                                    var area = ((IEnumerable<CutoverManager.Application.DTOs.AreaDTO>)ViewBag.Areas)
                                               .FirstOrDefault(a => a.Id == e.IdArea);

                                    <tr>
                                        <td>@area?.Nome</td>
                                        <td><strong>@e.Nome</strong></td>
                                        <td>@e.Email</td>
                                        <td>
                                            <a href="/Executor/Edit/@e.Id">
                                                Editar
                                            </a>
                                        </td>
                                        <td>
                                            <a href="/Executor/Delete/@e.Id" class="text-danger">
                                                Deletar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="card-footer">
                        <div class="row g-2 justify-content-center justify-content-sm-between">
                            <div class="col-auto d-flex align-items-center">
                                <p class="m-0 text-secondary">Mostrando <strong>@Model.Count()</strong> registros</p>
                            </div>
                            <div class="col-auto">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- END PAGE BODY -->