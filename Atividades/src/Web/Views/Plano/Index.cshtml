@model IEnumerable<CutoverManager.Application.DTOs.PlanoDTO>
@{
    ViewData["Title"] = "Planos";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">
            <i class="fas fa-calendar-alt"></i> Planos
        </h3>

        <a href="/Plano/Create" class="btn btn-light text-primary">
            <i class="fas fa-plus"></i> Novo Plano
        </a>
    </div>

    <div class="card-body">

        <form method="get" class="form-inline mb-3">
            <input name="nome" value="@Context.Request.Query["nome"]"
                   class="form-control mr-2" placeholder="Pesquisar por nome..." />
            <button class="btn btn-secondary"><i class="fas fa-search"></i> Buscar</button>
        </form>

        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>Nome</th>
                    <th>Início</th>
                    <th>Término</th>
                    <th>Status</th>
                    <th style="width:170px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.Nome</strong></td>
                        <td>@p.Inicio.ToString("dd/MM/yyyy")</td>
                        <td>@p.Termino.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (p.Status == CutoverManager.Domain.Enums.StatusPlano.Ativo)
                            {
                                <span class="badge badge-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Inativo</span>
                            }
                        </td>
                        <td>
                            <a href="/Plano/Edit/@p.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-edit"></i>
                            </a>

                            <a href="/Plano/Delete/@p.Id" class="btn btn-sm btn-danger ml-1">
                                <i class="fas fa-trash"></i>
                            </a>

                            <a href="/Atividade/Index?idPlano=@p.Id" class="btn btn-sm btn-primary ml-1">
                                <i class="fas fa-tasks"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>