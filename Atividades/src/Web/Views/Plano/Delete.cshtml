@model CutoverManager.Application.DTOs.PlanoDTO
@{
    ViewData["Title"] = "Excluir Plano";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0"><i class="fas fa-trash"></i> Excluir Plano</h4>
    </div>

    <div class="card-body">

        <p class="mb-3">
            Tem certeza que deseja excluir o plano:
            <strong>@Model.Nome</strong>?
        </p>

        <form method="post">

            <button class="btn btn-danger">
                <i class="fas fa-trash"></i> Excluir
            </button>

            <a href="/Plano" class="btn btn-secondary ml-2">Cancelar</a>

        </form>

    </div>
</div>