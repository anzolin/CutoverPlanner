@model CutoverManager.Application.DTOs.AreaDTO
@{
    ViewData["Title"] = "Editar Área";
}

<div class="card shadow-sm">
    <div class="card-header bg-info text-white">
        <h4 class="mb-0"><i class="fas fa-edit"></i> Editar Área</h4>
    </div>

    <div class="card-body">

        <form method="post">

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label>Nome *</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Nome do Responsável</label>
                <input asp-for="NomeResponsavel" class="form-control" />
            </div>

            <div class="form-group">
                <label>Email do Responsável</label>
                <input asp-for="EmailResponsavel" class="form-control" />
            </div>

            <button class="btn btn-info">
                <i class="fas fa-save"></i> Atualizar
            </button>

            <a href="/Area" class="btn btn-secondary">Voltar</a>

        </form>

    </div>
</div>