@model IEnumerable<CutoverManager.Application.DTOs.AreaDTO>
@{
    ViewData["Title"] = "Áreas";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">
            <i class="fas fa-building"></i> Áreas
        </h3>

        <a href="/Area/Create" class="btn btn-light text-primary">
            <i class="fas fa-plus"></i> Nova Área
        </a>
    </div>

    <div class="card-body">

        <table class="table table-hover table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Nome</th>
                    <th>Responsável</th>
                    <th>Email</th>
                    <th style="width: 150px">Ações</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td><strong>@a.Nome</strong></td>
                        <td>@a.NomeResponsavel</td>
                        <td>@a.EmailResponsavel</td>

                        <td>
                            <a href="/Area/Edit/@a.Id" class="btn btn-sm btn-info">
                                <i class="fas fa-edit"></i>
                            </a>

                            <a href="/Area/Delete/@a.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>