@model CutoverManager.Application.DTOs.AreaDTO
@{
    ViewData["Title"] = "Excluir Área";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4 class="mb-0"><i class="fas fa-trash"></i> Excluir Área</h4>
    </div>

    <div class="card-body">

        <p>
            Deseja realmente excluir a área:<br />
            <strong>@Model.Nome</strong>?
        </p>

        <form method="post">

            <button class="btn btn-danger">
                <i class="fas fa-trash"></i> Excluir
            </button>

            <a href="/Area" class="btn btn-secondary">Cancelar</a>

        </form>

    </div>
</div>