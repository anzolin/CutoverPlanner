@{
    ViewData["Title"] = "Selecionar Plano para o Kanban";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h3 class="mb-0">
            <i class="fas fa-columns"></i> Kanban – Selecionar Plano</h3>
    </div>

    <div class="card-body">
        <p class="text-muted">Escolha um plano para visualizar o Kanban.</p>

        @if (ViewBag.Planos == null || ViewBag.Planos.Count == 0)
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i>
                Nenhum plano cadastrado.
            </div>
        }
        else
        {
            <ul class="list-group">
                @foreach (var p in ViewBag.Planos)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@p.Nome</span>

                        <a class="btn btn-sm btn-primary" 
                            href="/Kanban/Index?idPlano=@p.Id">
                            Selecionar <i class="fas fa-arrow-right ml-1"></i>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</div>