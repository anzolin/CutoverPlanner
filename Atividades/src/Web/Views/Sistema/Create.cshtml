@model CutoverManager.Application.DTOs.SistemaDTO
@{
    ViewData["Title"] = "Novo Sistema";
}

<div class="card shadow-sm">
    <div class="card-header bg-success text-white">
        <h4><i class="fas fa-plus"></i> Novo Sistema</h4>
    </div>

    <div class="card-body">

        <form method="post">

            <div class="form-group">
                <label>Nome *</label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Área *</label>
                <select asp-for="IdArea" class="form-control"
                        asp-items="@(new SelectList(ViewBag.Areas, "Id", "Nome"))">
                </select>
            </div>

            <button class="btn btn-success">
                <i class="fas fa-save"></i> Salvar
            </button>

            <a href="/Sistema">Voltar</a>

        </form>

    </div>
</div>