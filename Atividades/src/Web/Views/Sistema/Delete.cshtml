@model CutoverManager.Application.DTOs.SistemaDTO
@{
    ViewData["Title"] = "Excluir Sistema";
}

<div class="card shadow-sm">
    <div class="card-header bg-danger text-white">
        <h4><i class="fas fa-trash"></i> Excluir Sistema</h4>
    </div>

    <div class="card-body">

        <p class="mb-3">
            Tem certeza que deseja excluir o sistema:
            <strong>@Model.Nome</strong>?
        </p>

        <form method="post">

            <button class="btn btn-danger">
                <i class="fas fa-trash"></i> Excluir
            </button>

            <a href="/Sistema">Voltar</a>

        </form>

    </div>
</div>