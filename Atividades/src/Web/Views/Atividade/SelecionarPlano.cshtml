@{
    ViewData["Title"] = "Selecionar Plano";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h3 class="card-title mb-0">
            <i class="fas fa-calendar-alt"></i> Selecionar Plano para Visualizar Atividades
        </h3>
    </div>

    <div class="card-body">

        <p class="text-muted mb-3">
            Escolha um plano abaixo para visualizar, cadastrar ou gerenciar as atividades.
        </p>

        @if (ViewBag.Planos == null || ViewBag.Planos.Count == 0)
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i>
                Nenhum plano cadastrado.
            </div>
        }
        else
        {
            <ul class="list-group">
                @foreach (var p in ViewBag.Planos)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>
                            <i class="fas fa-folder-open text-primary mr-2"></i>
                            @p.Nome
                        </span>

                        <a class="btn btn-sm btn-primary"
                               href="/Atividade/Index?idPlano=@p.Id">
                            Selecionar <i class="fas fa-arrow-right ml-1"></i>
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</div>