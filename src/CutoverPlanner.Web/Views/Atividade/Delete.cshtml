@model CutoverPlanner.Domain.Models.Atividade

@{
    ViewData["Title"] = "Excluir Atividade";
}

<h1>Excluir Atividade</h1>

<h3>Tem certeza que deseja excluir esta atividade?</h3>
<div>
    <h4>@Model.Titulo</h4>
    <dl class="row">
        <dt class="col-sm-2">Sistema</dt>
        <dd class="col-sm-10">@Model.Sistema?.Nome</dd>
        <dt class="col-sm-2">Executor</dt>
        <dd class="col-sm-10">@Model.Executor?.Nome</dd>
        <dt class="col-sm-2">Marco</dt>
        <dd class="col-sm-10">@Model.Marco?.Nome</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>