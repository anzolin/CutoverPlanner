@model CutoverPlanner.Domain.Models.Atividade

@{
    ViewData["Title"] = "Detalhes da Atividade";
}

<h1>Detalhes</h1>
<div>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>
        <dt class="col-sm-2">Título</dt>
        <dd class="col-sm-10">@Model.Titulo</dd>
        <dt class="col-sm-2">Sistema</dt>
        <dd class="col-sm-10">@Model.Sistema?.Nome</dd>
        <dt class="col-sm-2">Executor</dt>
        <dd class="col-sm-10">@Model.Executor?.Nome</dd>
        <dt class="col-sm-2">Marco</dt>
        <dd class="col-sm-10">@Model.Marco?.Nome</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
        <dt class="col-sm-2">Início</dt>
        <dd class="col-sm-10">@Model.Inicio?.ToString("dd/MM/yyyy")</dd>
        <dt class="col-sm-2">Término</dt>
        <dd class="col-sm-10">@Model.Termino?.ToString("dd/MM/yyyy")</dd>
        <dt class="col-sm-2">Observação</dt>
        <dd class="col-sm-10">@Model.Observacao</dd>
    </dl>
</div>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id">Editar</a> |
    <a asp-action="Index">Voltar à lista</a>
</p>