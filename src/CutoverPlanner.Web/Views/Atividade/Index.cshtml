@model IEnumerable<CutoverPlanner.Domain.Models.Atividade>

@{
    ViewData["Title"] = "Atividades";
}

<h1>Atividades</h1>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-2">
            <input type="text" name="busca" placeholder="Buscar..." value="@ViewData["busca"]" class="form-control" />
        </div>
        <div class="col-md-2">
            <input type="text" name="sistema" placeholder="Sistema..." value="@ViewData["sistema"]" class="form-control" />
        </div>
        <div class="col-md-2">
            <input type="text" name="executor" placeholder="Executor..." value="@ViewData["executor"]" class="form-control" />
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary">Filtrar</button>
        </div>
    </div>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova Atividade</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Marco</th>
            <th>Sistema</th>
            <th>Título</th>
            <th>Executor</th>
            <th>Início</th>
            <th>Término</th>
            <th>Atraso (dias)</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Marco?.Nome</td>
            <td>@item.Sistema?.Nome</td>
            <td>@item.Titulo</td>
            <td>
                @item.Executor?.Nome
                @if(item.Executor?.Area?.Nome != null)
                {
                    <br />
                    <small><strong>@item.Executor?.Area?.Nome</strong></small>
                    <br />
                    <small>@item.Executor?.Area?.NomeResponsavel</small>
                }
            </td>
            <td>@item.Inicio?.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.Termino?.ToString("dd/MM/yyyy HH:mm")</td>
              <td>
                @if (item.Status != StatusAtividade.Concluido && item.Termino.HasValue && item.Termino.Value.Date < DateTime.Today)
                {
                  var dias = (DateTime.Today - item.Termino.Value.Date).Days;
                  <span class="badge bg-danger">@dias</span>
                }
              </td>
            <td>
                @if (item.Status == StatusAtividade.Concluido)
                {
                  <span class="badge bg-success">@item.Status</span>
                }
                else if (item.Status == StatusAtividade.EmAndamento)
                {
                  <span class="badge bg-info">@item.Status</span>
                }
                else
                {
                  <span class="badge bg-danger">@item.Status</span>
                  
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Detalhes</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>