@model IEnumerable<CutoverPlanner.Domain.Models.Atividade>

@{
    ViewData["Title"] = "Atividades";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Pesquisa de @ViewData["Title"]</h3>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="mb-3">
            <div class="row">
                <div class="col-md-2">
                    <input type="text" name="busca" placeholder="Buscar..." value="@ViewData["busca"]" class="form-control" />
                </div>
                <div class="col-md-2">
                    <input type="text" name="sistema" placeholder="Sistema..." value="@ViewData["sistema"]" class="form-control" />
                </div>
                <div class="col-md-2">
                    <input type="text" name="executor" placeholder="Executor..." value="@ViewData["executor"]" class="form-control" />
                </div>
                <div class="col-md-2">
                    @{ var selectedStatus = ViewData["status"].ToString(); }
                    <select class="form-select" name="status">
                        <option value="">-- Status --</option>
                        @if (selectedStatus == "NaoIniciado")
                        {
                            <option value="NaoIniciado" selected>Não Iniciado</option>
                        }
                        else
                        {
                            <option value="NaoIniciado">Não Iniciado</option>
                        }
                        @if (selectedStatus == "EmAndamento")
                        {
                            <option value="EmAndamento" selected>Em Andamento</option>
                        }
                        else
                        {
                            <option value="EmAndamento">Em Andamento</option>
                        }
                        @if (selectedStatus == "Concluido")
                        {
                            <option value="Concluido" selected>Concluído</option>
                        }
                        else
                        {
                            <option value="Concluido">Concluído</option>
                        }
                        </select>
                </div>
                <div class="col-md-2">
                    <input class="form-check-input" type="checkbox" id="atrasadas" name="atrasadas" value="true" @(ViewBag.AtrasadasFilter == true ? "checked" : "") />
                    <label class="form-check-label" for="atrasadas">Atrasadas</label>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                </div>
            </div>
        </form>

        <hr />

        <div class="btn-group">
            <a asp-action="Create" class="btn btn-primary">Nova Atividade</a>
            <a asp-action="Index" class="btn btn-default">Atualizar</a>
            <a asp-action="ImportarExcel" class="btn btn-default">Importar Excel</a>
            @{
                var queryString = ViewContext.HttpContext.Request.QueryString.ToString();
                var exportUrl = "/Atividade/ExportarExcel" + queryString;
            }
            <a href="@exportUrl" class="btn btn-default">Exportar Excel</a>
            <form method="post" action="/Atividade/ExcluirTodas" style="display:inline" onsubmit="return confirm('Tem certeza que deseja excluir todas as atividades?');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger ms-2">Excluir Todas</button>
            </form>
        </div>

        <hr />

        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Sistema</th>
                    <th>Título</th>
                    <th>Executor</th>
                    <th>Início</th>
                    <th>Término</th>
                    <th>Atraso</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @{
                    var grouped = Model.GroupBy(a => a.Marco?.Nome ?? "Sem Marco")
                                       .OrderBy(g => g.Key);
                }
                @foreach (var group in grouped)
                {
                    <tr class="table-secondary">
                        <td colspan="9"><strong>🎯 @group.Key</strong></td>
                    </tr>
                    @foreach (var item in group.OrderBy(a => a.Inicio ?? DateTime.MaxValue))
                    {
                        <tr>
                            <td>@item.Sistema?.Nome</td>
                            <td>
                                @if (item.RiscoGoLive)
                                {
                                    <small class="text-xs text-danger">Risco de GoLive</small><br />
                                }
                                <a asp-action="Details" asp-route-id="@item.Id">
                                    <strong>@item.Titulo</strong>
                                </a>
                            </td>
                            <td>
                                @item.Executor?.Nome
                                @if (item.Executor?.Area?.Nome != null)
                                {
                                    <br /><small class="text-xs text-muted">@item.Executor?.Area?.Nome</small>
                                }
                            </td>
                            <td>@item.Inicio?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.Termino?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.Status != StatusAtividade.Concluido && item.Termino.HasValue && item.Termino.Value.Date < DateTime.Today)
                                {
                                    var dias = (DateTime.Today - item.Termino.Value.Date).Days;
                                    <span class="badge bg-danger">@dias</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == StatusAtividade.Concluido)
                                {
                                    <span class="badge bg-success">Concluído</span>
                                }
                                else if (item.Status == StatusAtividade.EmAndamento)
                                {
                                    <span class="badge bg-warning">Em Andamento</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Pendente</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                                <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>