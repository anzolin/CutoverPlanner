
@{
    ViewData["Title"] = "Importar Planilha";
}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Importar Planilha (.xlsx)</h3>
  </div>
  <div class="card-body">
    <form method="post" enctype="multipart/form-data" action="/Import/Upload">
      <div class="mb-3">
        <label for="file" class="form-label">Selecione o arquivo Excel (.xlsx)</label>
        <input type="file" name="file" id="file" accept=".xlsx" class="form-control" />
      </div>
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-upload"></i> Importar
      </button>
    </form>
    @if (TempData["Msg"] != null)
    {
      <div class="alert alert-success mt-3">@TempData["Msg"]</div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger mt-3">@TempData["Error"]</div>
    }
  </div>
</div>
