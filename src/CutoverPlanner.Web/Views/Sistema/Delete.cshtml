@model CutoverPlanner.Domain.Models.Sistema

@{
    ViewData["Title"] = "Excluir Sistema";
}

<h1>Excluir Sistema</h1>

<h3>Tem certeza que deseja excluir este sistema?</h3>
<div>
    <h4>@Model.Nome</h4>
    <dl class="row">
        <dt class="col-sm-2">Área</dt>
        <dd class="col-sm-10">@Model.Area?.Nome</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>