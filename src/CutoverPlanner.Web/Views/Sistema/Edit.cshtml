@model CutoverPlanner.Domain.Models.Sistema

@{
    ViewData["Title"] = "Editar Sistema";
}

<h1>Editar Sistema</h1>

<div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Nome"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="IdArea">Área</label>
        <select asp-for="IdArea" class="form-control" asp-items="ViewBag.Areas"></select>
        <span asp-validation-for="IdArea" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}