@model CutoverPlanner.Domain.Models.Plano

@{
    ViewData["Title"] = "Detalhes do Plano";
}

<h1>Detalhes</h1>
<div>
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Nome</dd>
        <dt class="col-sm-2">Início</dt>
        <dd class="col-sm-10">@Model.Inicio?.ToString("dd/MM/yyyy HH:mm")</dd>
        <dt class="col-sm-2">Término</dt>
        <dd class="col-sm-10">@Model.Termino?.ToString("dd/MM/yyyy HH:mm")</dd>
    </dl>
</div>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id">Editar</a> |
    <a asp-action="Index">Voltar à lista</a>
</p>