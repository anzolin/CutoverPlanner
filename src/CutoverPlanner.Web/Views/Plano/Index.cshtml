@model IEnumerable<CutoverPlanner.Domain.Models.Plano>

@{
    ViewData["Title"] = "Planos";
}

<h1>Planos</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">Novo Plano</a>
</p>
<table class="table table-striped table-hover table-bordered">
    <thead>
        <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Início</th>
            <th>Término</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Id</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">
                    <strong>@item.Nome</strong>
                </a>
            </td>
            <td>@item.Inicio?.ToString("dd/MM/yyyy HH:mm")</td>
            <td>@item.Termino?.ToString("dd/MM/yyyy HH:mm")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Editar</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Excluir</a>
            </td>
        </tr>
}
    </tbody>
</table>