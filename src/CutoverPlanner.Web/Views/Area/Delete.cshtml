@model CutoverPlanner.Domain.Models.Area

@{
    ViewData["Title"] = "Excluir Área";
}

<h1>Excluir Área</h1>

<h3>Tem certeza que deseja apagar esta área?</h3>
<div>
    <h4>@Model.Nome</h4>
    <dl class="row">
        <dt class="col-sm-2">Responsável</dt>
        <dd class="col-sm-10">@Model.NomeResponsavel</dd>
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.EmailResponsavel</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Excluir</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>