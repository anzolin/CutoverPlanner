
@model IEnumerable<CutoverPlanner.Web.Models.Atividade>
@{
    ViewData["Title"] = "Atividades";
    var query = ViewContext.HttpContext.Request.Query;
}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">Atividades</h3>
    <div class="card-tools">
      <a class="btn btn-primary btn-sm" href="/Atividades/Criar">
        <i class="bi bi-plus-lg"></i> Nova Atividade
      </a>
      @{
        var queryString = ViewContext.HttpContext.Request.QueryString.ToString();
        var exportUrl = "/Atividades/ExportarExcel" + queryString;
      }
      <a class="btn btn-success btn-sm" href="@exportUrl">
        <i class="bi bi-download"></i> Exportar Excel
      </a>
      <form method="post" action="/Atividades/ExcluirTodas" style="display:inline" onsubmit="return confirm('Tem certeza que deseja excluir todas as atividades?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger btn-sm">
          <i class="bi bi-trash"></i> Excluir Todas
        </button>
      </form>
    </div>
  </div>
  <div class="card-body">
    @if (ViewBag.DefaultApplied == true)
    {
      <div class="alert alert-info">Filtro padrão aplicado: Área = <b>@ViewBag.DefArea</b>, Status ≠ <b>@ViewBag.DefStatusNot</b>. Altere os filtros pelo formulário abaixo.</div>
    }
    <form method="get" class="row g-2 mb-3">
      <div class="col-auto">
        <input class="form-control" name="sistema" placeholder="Sistema" value="@query["sistema"]" />
      </div>
      <div class="col-auto">
        <input class="form-control" name="area" placeholder="Área Executora" value="@query["area"]" />
      </div>
      <div class="col-auto">
        <input class="form-control" name="responsavel" placeholder="Responsável" value="@query["responsavel"]" />
      </div>
      <div class="col-auto">
        @{ var selectedStatus = query["status"].ToString(); }
        <select class="form-select" name="status">
          <option value="">-- Status --</option>
          @if (selectedStatus == "NaoIniciado")
          {
            <option value="NaoIniciado" selected>Não Iniciado</option>
          }
          else
          {
            <option value="NaoIniciado">Não Iniciado</option>
          }
          @if (selectedStatus == "EmAndamento")
          {
            <option value="EmAndamento" selected>Em Andamento</option>
          }
          else
          {
            <option value="EmAndamento">Em Andamento</option>
          }
          @if (selectedStatus == "Concluido")
          {
            <option value="Concluido" selected>Concluído</option>
          }
          else
          {
            <option value="Concluido">Concluído</option>
          }
        </select>
      </div>
      <div class="col-auto">
        <input class="form-control" name="busca" placeholder="Busca" value="@query["busca"]" />
      </div>
      <div class="col-auto form-check align-self-center">
        <input class="form-check-input" type="checkbox" id="atrasadas" name="atrasadas" value="true" @(ViewBag.AtrasadasFilter == true ? "checked" : "") />
        <label class="form-check-label" for="atrasadas">Atrasadas</label>
      </div>
      <div class="col-auto">
        <button class="btn btn-secondary" type="submit">Filtrar</button>
      </div>
    </form>
    <div class="table-responsive">
      <table class="table table-sm table-hover">
        <thead>
          <tr>
            <th>ID</th><th>Sistema</th><th>Título</th><th>Área</th><th>Status</th><th>Start</th><th>End</th><th>Atraso (dias)</th><th></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var a in Model)
          {
            <tr>
              <td>@a.IdPlanilha</td>
              <td>@a.Sistema</td>
              <td><a href="/Atividades/Detalhes/@a.Id">@a.Titulo</a></td>
              <td>@a.AreaExecutoraNome</td>
              <td>
                @if (a.Status == StatusAtividade.Concluido)
                {
                  <span class="badge bg-success">@a.Status</span>
                }
                else if (a.Status == StatusAtividade.EmAndamento)
                {
                  <span class="badge bg-info">@a.Status</span>
                }
                else
                {
                  <span class="badge bg-danger">@a.Status</span>
                  
                }
              </td>
              <td>@a.Start?.ToString("dd/MM/yyyy")</td>
              <td>@a.End?.ToString("dd/MM/yyyy")</td>
              <td>
                @if (a.Status != StatusAtividade.Concluido && a.End.HasValue && a.End.Value.Date < DateTime.Today)
                {
                  var dias = (DateTime.Today - a.End.Value.Date).Days;
                  <span class="badge bg-danger">@dias</span>

                }
              </td>
              <td>

                <div class="btn-group" role="group">
                  <a class="btn btn-sm btn-outline-primary" href="/Atividades/Editar/@a.Id"><i class="bi bi-pencil"></i></a>
                  <button type="button" class="btn btn-sm btn-outline-danger" onclick="if(confirm('Excluir?')) { document.getElementById('form-delete-@a.Id').submit(); }"><i class="bi bi-trash"></i></button>
                  <form id="form-delete-@a.Id" method="post" action="/Atividades/Excluir/@a.Id" style="display:none;">
                    @Html.AntiForgeryToken()
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
</div>
