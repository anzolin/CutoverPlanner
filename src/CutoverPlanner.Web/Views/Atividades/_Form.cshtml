@model CutoverPlanner.Web.Models.Atividade

@* The parent view should set ViewData["Action"] to either "Criar" or "Editar" *@
<form asp-action="@ViewData["Action"]" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="Sistema" class="form-label"></label>
                <input asp-for="Sistema" class="form-control" />
                <span asp-validation-for="Sistema" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Milestone" class="form-label"></label>
                <input asp-for="Milestone" class="form-control" />
                <span asp-validation-for="Milestone" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Titulo" class="form-label"></label>
                <input asp-for="Titulo" class="form-control" />
                <span asp-validation-for="Titulo" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Categoria" class="form-label"></label>
                <input asp-for="Categoria" class="form-control" />
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RequerTestePerformance" class="form-check-input" />
                <label asp-for="RequerTestePerformance" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="TipoTeste" class="form-label"></label>
                <input asp-for="TipoTeste" class="form-control" />
                <span asp-validation-for="TipoTeste" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Procedimento" class="form-label"></label>
                <textarea asp-for="Procedimento" class="form-control"></textarea>
                <span asp-validation-for="Procedimento" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Metricas" class="form-label"></label>
                <textarea asp-for="Metricas" class="form-control"></textarea>
                <span asp-validation-for="Metricas" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="mb-3">
                <label asp-for="CriterioAceite" class="form-label"></label>
                <textarea asp-for="CriterioAceite" class="form-control"></textarea>
                <span asp-validation-for="CriterioAceite" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Evidencias" class="form-label"></label>
                <textarea asp-for="Evidencias" class="form-control"></textarea>
                <span asp-validation-for="Evidencias" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Responsavel" class="form-label"></label>
                <input asp-for="Responsavel" class="form-control" />
                <span asp-validation-for="Responsavel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="AreaExecutoraNome" class="form-label"></label>
                <input asp-for="AreaExecutoraNome" class="form-control" />
                <span asp-validation-for="AreaExecutoraNome" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Executor" class="form-label"></label>
                <input asp-for="Executor" class="form-control" />
                <span asp-validation-for="Executor" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<StatusAtividade>()"></select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RiscoGoLive" class="form-check-input" />
                <label asp-for="RiscoGoLive" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="Start" class="form-label"></label>
                <input asp-for="Start" type="datetime-local" class="form-control" />
                <span asp-validation-for="Start" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="End" class="form-label"></label>
                <input asp-for="End" type="datetime-local" class="form-control" />
                <span asp-validation-for="End" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Observacao" class="form-label"></label>
                <textarea asp-for="Observacao" class="form-control"></textarea>
                <span asp-validation-for="Observacao" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LinkRepositorio" class="form-label"></label>
                <input asp-for="LinkRepositorio" class="form-control" />
                <span asp-validation-for="LinkRepositorio" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PredecessorasRaw" class="form-label"></label>
                <input asp-for="PredecessorasRaw" class="form-control" />
                <span asp-validation-for="PredecessorasRaw" class="text-danger"></span>
                <small class="form-text text-muted">Digite IDs separados por vírgula</small>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
</form>
