
@model CutoverPlanner.Web.Models.Atividade
<div class="mb-3">
    <a href="@ViewBag.BackUrl" class="btn btn-secondary">← Voltar</a>
</div>
<h2>Detalhes da Atividade</h2>
<dl class="row">
  <dt class="col-sm-3">Sistema</dt><dd class="col-sm-9">@Model.Sistema</dd>
  <dt class="col-sm-3">Milestone</dt><dd class="col-sm-9">@Model.Milestone</dd>
  <dt class="col-sm-3">Título</dt><dd class="col-sm-9">@Model.Titulo</dd>
  <dt class="col-sm-3">Responsável</dt><dd class="col-sm-9">@Model.Responsavel</dd>
  <dt class="col-sm-3">Área</dt><dd class="col-sm-9">@Model.AreaExecutoraNome</dd>
  <dt class="col-sm-3">Executor</dt><dd class="col-sm-9">@Model.Executor</dd>
  <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
  <dt class="col-sm-3">Risco Go-live</dt><dd class="col-sm-9">@(Model.RiscoGoLive ? "Sim" : "Não")</dd>
  <dt class="col-sm-3">Início</dt><dd class="col-sm-9">@Model.Start?.ToString("dd/MM/yyyy HH:mm")</dd>
  <dt class="col-sm-3">Fim</dt><dd class="col-sm-9">@Model.End?.ToString("dd/MM/yyyy HH:mm")</dd>
  <dt class="col-sm-3">Observação</dt><dd class="col-sm-9">@Model.Observacao</dd>
  <dt class="col-sm-3">Repositório</dt><dd class="col-sm-9"><a href="@Model.LinkRepositorio" target="_blank">@Model.LinkRepositorio</a></dd>
</dl>
